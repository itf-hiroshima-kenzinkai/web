---
import '../styles/global.css'
---

<div class="block md:hidden">
  <div class="hamburger pr-5 cursor-pointer group relative w-10 h-8 z-50">
    <span
      class="line block w-10 h-1.5 bg-[#E93A3A] absolute top-0 left-0
               transition ease-in-out duration-300
               group-[&.expanded]:translate-y-[13px] group-[&.expanded]:rotate-45"
    ></span>

    <span
      class="line block w-10 h-1.5 bg-[#E93A3A] absolute top-1/2 left-0 -translate-y-1/2
               transition ease-in-out duration-300
               group-[&.expanded]:opacity-0"
    ></span>

    <span
      class="line block w-10 h-1.5 bg-[#E93A3A] absolute bottom-0 left-0
               transition ease-in-out duration-300
               group-[&.expanded]:-translate-y-[13px] group-[&.expanded]:-rotate-45"
    ></span>
  </div>

  <nav
    class="nav-links
              fixed top-0 right-0 h-full w-64 bg-[#F0F0F0] z-40 rounded-l-2xl shadow-lg
              transition-transform duration-300 ease-in-out
              transform translate-x-full
              md:hidden
              [&.expanded]:translate-x-0
              p-6"
  >
    <ul class="font-jaro text-[#E93A3A] text-2xl underline">
      <li class="mt-6 mb-4"><a href="/">TOP</a></li>
      <li class="mb-4"><a href="/about">ABOUT</a></li>
      <li class="mb-4"><a href="/goods">GOODS</a></li>
      <li class="mb-4"><a href="/supecial">50th</a></li>
      <li class="mb-4"><a href="/contact">CONTACT</a></li>
    </ul>
  </nav>
</div>

<script>
  import '../components/hamberger.js'
</script>

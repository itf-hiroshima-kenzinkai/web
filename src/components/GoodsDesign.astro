---
import '../styles/global.css'
const { sentence, number, link1, link2, link3, link4, goods1, goods2, goods3, goods4 } = Astro.props
---

<div class="w-full sm:w-1/2 md:w-1/3 p-4">
  <div class="rounded-2xl shadow-lg overflow-hidden bg-white">
    <img src={`/goods_${number}.JPG`} alt={`画像${number}`} class="w-full aspect-[4/3] object-contain" />
    <div class="bg-[#E93A3A] font-zenmaru text-white text-sm p-4 md:text-base md:p-8 md:leading-relaxed">
      <p>{sentence}</p>
      <br />
      <span class = "font-bold">販売アイテム一覧</span>
      <a
        href={link1}
        class="group flex w-full items-center justify-between underline md:no-underline md:hover:underline decoration-white/50 hover:opacity-80 transition duration-200"
      >
        <span>{goods1}</span>
        <svg
          class="h-4 w-4 transform transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <a
        href={link2}
        class="group flex w-full items-center justify-between underline md:no-underline md:hover:underline decoration-white/50 hover:opacity-80 transition"
      >
        <span>{goods2}</span>
        <svg
          class="h-4 w-4 transform transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <a
        href={link3}
        class="group flex w-full items-center justify-between underline md:no-underline md:hover:underline decoration-white/50 hover:opacity-80 transition"
      >
        <span>{goods3}</span>
        <svg
          class="h-4 w-4 transform transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>

      <a
        href={link4}
        class="group flex w-full items-center justify-between underline md:no-underline md:hover:underline decoration-white/50 hover:opacity-80 transition"
      >
        <span>{goods4}</span>
        <svg
          class="h-4 w-4 transform transition-transform group-hover:translate-x-1"
          fill="none"
          viewBox="0 0 24 24"
          stroke="currentColor"
          stroke-width="2"
        >
          <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7"></path>
        </svg>
      </a>
    </div>
  </div>
</div>

---
import '../styles/global.css'
const { sentence, number, link1, link2, link3, link4, goods1, goods2, goods3, goods4 } = Astro.props
---

<div class="w-full sm:w-1/2 md:w-1/3 p-4">
  <div class="rounded-2xl shadow-lg overflow-hidden bg-white">
    <img src={`/goods_${number}.JPG`} alt={`画像${number}`} class="w-full aspect-[4/3] object-contain" />
    <div class="bg-[#E93A3A] font-zenmaru text-white text-sm p-4">
      <p>{sentence}</p>
      <br />
      <span class="font-bold">販売グッズ</span>
      <p><a href={link1} class="hover:underline">・{goods1}</a></p>
      <p><a href={link2} class="hover:underline">・{goods2}</a></p>
      <p><a href={link3} class="hover:underline">・{goods3}</a></p>
      <p><a href={link4} class="hover:underline">・{goods4}</a></p>
    </div>
  </div>
</div>

---
import Layout from '../layouts/Layout.astro'
import '../styles/global.css'
import IndexContentCard from '../components/IndexContentCard.astro'
import GoodsCarousel from '../components/GoodsCarousel'
const pagetitle = '筑波大学広島県人会'
const aboutImageClass = 'object-contain h-auto w-full mb-8 md:mb-0 md:w-2/5'
const newsItems = [
  { date: '2026.04.04', label: 'お知らせ', title: 'トップページにNEWS欄を追加しました' },
  { date: '2026.03.20', label: 'イベント', title: '新歓向けの交流会を準備中です' },
  { date: '2026.03.01', label: '更新', title: '50th PAGEの案内を更新しました' }
]
---

<Layout pagetitle={pagetitle}>
  <div class="flex flex-col justify-center items-center">
    <div class="flex justify-center flex-col items-center w-full">
      <div class="relative hidden font-jaro text-9xl text-[#E93A3A] text-stroke-white xl:block">
        <p class="absolute top-0 left-[5%] animate-slide-in-left">Univ. of TSUKUBA</p>
        <img src="/mainpic.png" class="relative z-[-1] w-[65%] block mx-auto" />
        <p class="absolute bottom-[-2%] right-[5%] animate-slide-in-right">HIROSHIMA KENJINKAI</p>
      </div>

      <div
        class="flex flex-col justify-center items-center text-5xl md:text-7xl font-jaro w-[95%] text-[#E93A3A] text-center mt-2 xl:hidden"
      >
        <p>Univ.of TSUKUBA</p>
        <img src="/mainpic.png" class="w-[85%]" />
        <p>HIROSHIMA</p>
        <p>KENJINKAI</p>
      </div>
    </div>

    <IndexContentCard title={'NEWS'}>
      <div class="w-full text-white tracking-wider text-sm md:text-lg md:leading-loose">
        <ul class="space-y-4 md:space-y-5">
          {
            newsItems.map((item) => (
              <li class="rounded-2xl border border-white/20 bg-white/10 px-4 py-3 md:px-6 md:py-4">
                <p class="text-xs md:text-sm text-white/80">
                  {item.date} / {item.label}
                </p>
                <p class="mt-1 font-semibold">{item.title}</p>
              </li>
            ))
          }
        </ul>
      </div>
    </IndexContentCard>

    <IndexContentCard title={'ABOUT'}>
      <img
        src="/chibiCharaMomiji.png"
        class="absolute
      md:top-5 md:right-55 md:translate-x-full md:-translate-y-full md:w-1/8
      -top-20 right-10 w-1/4"
      />

      <img src="/about_image_noon.jpg" class={aboutImageClass} />

      <div class="flex-col text-white tracking-wider w-full md:w-3/5 my-0 text-sm md:text-xl md:leading-loose md:pt-12">
        <p>筑波大学広島県人会は、50年の歴史があり、広島出身の学生を中心に活動している公式サークルです。</p>
        <p class="hidden md:block">主な活動は、雙峰祭、やどかり祭でお好み焼きを焼くこと！</p>
        <p class="hidden md:block">
          その他、有志でカープ観戦に行くなど、学類や学年を超えてアットホームな雰囲気で交流しています！
        </p>
        <p>広島出身者はもちろん、カープが好きな人、広島に興味がある人も大歓迎です！</p>

        <div class="flex justify-end">
          <a href="/about" class="font-jaro text-right text-4xl my-4 hover:underline"> MORE…→ </a>
        </div>
      </div>
    </IndexContentCard>

    <IndexContentCard title={'GOODS'}>
      <img src="/chibiCharaLemon.png" class="absolute top-0 left-1/6 -translate-y-1/2 md:w-1/4 h-auto z-10 w-1/2" />
      <GoodsCarousel client:only="react" />
    </IndexContentCard>

    <IndexContentCard title={'50thPAGE'}>
      <div class="md:flex md:flex-row md:justify-center md:gap-12">
        <img src="/poster.png" class="w-full pb-4 md:w-1/3 object-contain md:pb-12" />

        <div class="text-white text-sm md:w-1/2 md:pt-12 md:text-xl md:leading-loose">
          <p>
            筑波大学広島県人会の50周年を記念してパーティーを開催予定です！
            <br />
            現役、OB/OGを問わず、この機会に交流を深めてみませんか？
            <br />
            詳細はMORE...からご覧ください！
          </p>
          <a href="/supecial" class="block text-white mt-4">
            <p class="font-jaro text-right text-4xl pb-4 hover:underline">MORE…→</p>
          </a>
        </div>
      </div>
    </IndexContentCard>
  </div>
</Layout>

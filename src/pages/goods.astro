---
import Layout from '../layouts/Layout.astro'
import '../styles/global.css'
import GoodsDesign from '../components/GoodsDesign.astro'
const pagetitle = 'グッズ'
---

<Layout pagetitle={pagetitle}>
  <body class="bg-white text-red-600">
    <main class="max-w-7xl mx-auto px-6 py-12">
      <p class="w-[95%] font-[Jaro] text-6xl text-[#E93A3A] mb-8 md:text-8xl">G O O D S</p>
      <p class="text-center">
        <a href="https://suzuri.jp/Hiroshima_kenjinkai_UnivTsukuba/products?sort=sales" class="inline-block">
          <button
            class="font-zenmaru font-bold text-3xl text-[#E93A3A] mb-8 md:text-5xl
          bg-white relative rounded-xl px-2
          hover:text-white hover:bg-[#E93A3A] hover:text-white
          after:content-[''] after:absolute after:left-1/2 after:mt-2 after:bottom-[-6px] after:w-[90%] after:h-[6px] after:bg-[#E93A3A] after:translate-x-[-50%]
          hover:after:opacity-0"
          >
            <div class="px-2 py-1">ショップを見る</div>
          </button>
        </a>
      </p>
      <br />
      <div
        class="text-center w-[95%] mx-auto font-zenmaru font-bold text-4xl text-[#E93A3A] mb-8 md:text-6xl leading-none"
      >
        デザイン一覧

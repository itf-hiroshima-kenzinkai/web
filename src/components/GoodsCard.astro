---
export interface Props {
  imageUrl: string
  price: number
  description: string
}

const { imageUrl, price, description } = Astro.props
---

<div class="flex-none w-1/3 p-4">
  <div class="bg-gray-300 w-full aspect-square flex items-center justify-center">
    <img src={imageUrl} alt={description} class="object-cover w-full h-full" />
  </div>
  <div class="mt-4 text-center">
    <p class="text-xl font-bold">{price.toLocaleString()} 円 (税込)</p>
    <p class="text-sm">{description}</p>
  </div>
</div>

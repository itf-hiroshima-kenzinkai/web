---
const posts = await Astro.glob('../../pages/news/*.md')

const cards = posts
  .map((post) => ({
    url: post.url ?? '',
    title: post.frontmatter?.title ?? '',
    description: post.frontmatter?.description ?? '',
    imageUrl: post.frontmatter?.image?.url ?? '',
    imageAlt: post.frontmatter?.image?.alt ?? '',
    pubDate: post.frontmatter?.pubDate ?? ''
  }))
  .sort((a, b) => b.pubDate.localeCompare(a.pubDate))
---

<section class="my-12 mx-auto font-zenmaru">
  {
    cards.length === 0 ? (
      <p class="text-sm text-gray-700">ニュースがまだありません。</p>
    ) : (
      <div class="flex flex-col gap-4">
        {cards.map((card) => (
          <article class="rounded-4xl bg-white border-4 border-[#E93A3A] overflow-hidden">
            <a class="flex items-center text-gray-700 no-underline" href={card.url}>
              <div class="min-w-0 ml-12 flex-1">
                {card.pubDate ? <p class="mb-1 text-xs text-gray-700">{card.pubDate}</p> : null}
                <p class="font-bold text-gray-700 text-xl underlin">{card.title}</p>
                {card.description ? <p class="text-sm leading-relaxed text-gray-700">{card.description}</p> : null}
              </div>

              {card.imageUrl ? (
                <div class="w-1/5 flex-shrink-0 mx-20 my-2 bg-white">
                  <img
                    class="h-full w-full object-cover rounded"
                    src={card.imageUrl}
                    alt={card.imageAlt || card.title}
                    loading="lazy"
                  />
                </div>
              ) : null}
            </a>
          </article>
        ))}
      </div>
    )
  }
</section>

---
import Layout from './Layout.astro'

const { pagetitle = 'ニュース', description } = Astro.props
---

<Layout pagetitle={pagetitle} description={description}>
  <main class="max-w-7xl mx-auto px-6 py-12 prose">
    <div class ="border border-[#E93A3A] border-4 rounded-2xl py-12 px-20 font-zenmaru">
      <p>{pagetitle}</p>
      <slot />
    </div>
  </main>
</Layout>

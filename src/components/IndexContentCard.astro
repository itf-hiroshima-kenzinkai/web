---
import '../styles/global.css'
const { title } = Astro.props
---

<div
  class="w-[80%] flex flex-col items-center justify-center bg-[#E93A3A] mt-20 md:mt-80 rounded-4xl position: relative"
>
  <p class="md : font-[Jaro] justify-center text-white text-4xl p-4 md:tracking-wider md:my-8 md:text-7xl">{title}</p>

  <div class="flex flex-col md:flex-row w-full px-16 font-zenmaru">
    <slot />
  </div>
</div>

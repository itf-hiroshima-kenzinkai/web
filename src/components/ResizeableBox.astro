---
 type Size = 'sm' | 'md' | 'lg' | 'xl';

interface Props {
  title?: string;
  size?: Size;
  extra?: string;
}

const { title = '', size = 'md', extra = '' } = Astro.props as Props;

const sizeMap: Record<Size, string> = {
  sm: 'w-64 h-40',
  md: 'w-80 h-48',
  lg: 'w-96 h-56',
  xl: 'w-[28rem] h-[12rem]',
};

const sizeClass = sizeMap[size] ?? sizeMap.md;


---
<div class={`bg-red-500 text-white rounded-2xl shadow-lg p-6 ${sizeClass} ${extra}`}>
      <slot />
</div>

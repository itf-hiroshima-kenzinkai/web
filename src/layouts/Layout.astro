---
import '../styles/global.css'
import Header from '../components/Header.astro'
import Footer from '../components/Footer.astro'
const { pagetitle, description = '筑波大学広島県人会の公式サイトです。' } = Astro.props
const siteTitle = '筑波大学広島県人会'
const pageTitle = pagetitle ?? siteTitle
const fullTitle = pageTitle === siteTitle ? siteTitle : `${siteTitle} | ${pageTitle}`
const ogImageUrl = new URL('/thumbnail.png', Astro.site)
const canonicalUrl = new URL(Astro.url.pathname, Astro.site)
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />

    <link rel="icon" type="image/svg+xml" href="/mainpic.svg" />

    <meta property="og:site_name" content="筑波大学広島県人会" />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content="1936" />
    <meta property="og:image:height" content="1094" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
  </head>

  <body class="bg-white">
    <header class="flex justify-end px-4 pt-2">
      <Header />
    </header>
    <slot />
    <Footer />
  </body>
</html>
